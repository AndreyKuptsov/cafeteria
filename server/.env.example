# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Тип БД: 'sqlite' (по умолчанию для разработки) или 'postgres' (для продакшена)
DB_TYPE=sqlite

# SQLite (для локальной разработки)
SQLITE_PATH=./database.sqlite

# PostgreSQL (для продакшена - раскомментируйте и настройте при миграции)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cafeteria_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# JWT Secret
JWT_SECRET=your_jwt_secret_key_change_in_production

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Payment Integration (placeholder for future)
PAYMENT_API_KEY=your_payment_api_key

# Taxi API (for delivery)
TAXI_API_KEY=your_taxi_api_key
TAXI_API_URL=https://api.taxi-service.com

# Business Hours
WEEKDAY_OPEN=10:00
WEEKDAY_CLOSE=20:00
WEEKEND_OPEN=12:00
WEEKEND_CLOSE=17:00

# Delivery Settings
DELIVERY_RADIUS_KM=5
MIN_ORDER_AMOUNT=500
